# ========================
# Terraform
# ========================
# State files contain sensitive info (IPs, resource IDs)
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl

# Variable files with YOUR specific values
# (someone else will have different values)
terraform/terraform.tfvars

# Crash logs
terraform/crash.log

# ========================
# SSH Keys (NEVER push these)
# ========================
*.pem
*.key

# ========================
# Python
# ========================
__pycache__/
*.py[cod]
*.pyc
.env
venv/
.venv/

# ========================
# Docker
# ========================
# Nothing critical to ignore, but good practice:
docker-compose.override.yml

# ========================
# OS Files
# ========================
.DS_Store
Thumbs.db

# ========================
# IDE / Editor
# ========================
.vscode/
.idea/
*.swp
*.swo

# ========================
# Environment & Secrets
# ========================
.env
*.env
.env.local
.env.production